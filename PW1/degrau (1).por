programa {
  funcao inicio() {
    real degrau, altura, resultado

    escreva("Informe o valor de um degrau da escada: ")
    leia(degrau)
    escreva("Informe a altura que voce quer atingir: ")
    leia(altura)
    resultado=(altura/degrau)

    escreva("A quantidade de degrau é: ", resultado)
  }
}
